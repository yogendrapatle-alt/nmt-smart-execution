# Optional. Leave unset for same-origin API calls:
# - Local: Vite proxies /api → http://127.0.0.1:5000 (see vite.config.ts)
# - Production bundle: `.env.production` clears VITE_* so `/api` goes through nginx on port 80
# - Do NOT set VITE_* to http://YOUR_VM:5000 for the VM — port 5000 is often blocked; use nginx on :80
#
# Set only if UI and API are on different origins (no proxy), e.g.:
# VITE_API_BASE_URL=http://other-host:5000
# Legacy alias:
# VITE_BACKEND_URL=http://127.0.0.1:5000
