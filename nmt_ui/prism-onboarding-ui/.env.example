# Optional. Leave unset for same-origin API calls:
# - Local: Vite proxies /api → http://127.0.0.1:5000 (see vite.config.ts)
# - VM: nginx proxies /api → backend :5000
#
# Set only if the UI and API are on different origins (no proxy):
# VITE_API_BASE_URL=http://10.117.66.44:5000
# Legacy alias:
# VITE_BACKEND_URL=http://127.0.0.1:5000
